# Qwen Chat Gateway Environment Variables

QWEN_WEB_URL=https://chat.qwen.ai
QWEN_HOST=127.0.0.1
QWEN_PORT=8787
QWEN_BROWSER_HEADLESS=false
QWEN_BROWSER_USER_DATA_DIR=./browser_data/qwen
QWEN_BROWSER_EXECUTABLE_PATH=
QWEN_MAX_CONCURRENCY=1
QWEN_MIN_INTERVAL_MS=60000
QWEN_STOP_ON_CHALLENGE=true
QWEN_ARTIFACTS_DIR=./artifacts
QWEN_LOCAL_API_KEY=
QWEN_STORE_PROMPTS=false

# Optional Selector Overrides (if Qwen Web UI changes)
